{
  "name": "omg-ai-mcp",
  "version": "1.0.0",
  "description": "OMG AI - Connect Google Search Console and Analytics to AI assistants via MCP",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:mcp": "tsx watch src/mcp/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:mcp\" --names web,mcp --prefix-colors green,blue",
    "build": "prisma migrate deploy && next build && tsc -p tsconfig.mcp.json",
    "build:mcp": "tsc -p tsconfig.mcp.json",
    "start": "concurrently \"next start --port 3000\" \"node dist/mcp/server.js\"",
    "start:mcp": "node dist/mcp/server.js",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@prisma/client": "^5.22.0",
    "concurrently": "^9.0.0",
    "express": "^4.21.0",
    "googleapis": "^144.0.0",
    "jose": "^5.9.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "stripe": "^20.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
