// GSC Connect - Database Schema
// Run: npx prisma migrate dev --name init
// Run: npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// User Accounts
// ============================================================
model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String?
  googleId         String?  @unique @map("google_id")
  passwordHash     String?  @map("password_hash")
  subscriptionTier String   @default("free") @map("subscription_tier") // free, pro, agency
  stripeCustomerId String?  @map("stripe_customer_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  googleCredentials GoogleCredential[]
  gscProperties     GscProperty[]
  ga4Properties     Ga4Property[]
  apiKeys           ApiKey[]
  oauthTokens       OAuthToken[]
  authCodes         OAuthAuthorizationCode[]
  subscription      UserSubscription?
  couponRedemptions CouponRedemption[]
  tickets           SupportTicket[]

  @@map("users")
}

// ============================================================
// Pricing Plans
// ============================================================
model Plan {
  id                       String   @id // e.g. "plan_free", "plan_pro", "plan_premium"
  name                     String   @unique // "free", "pro", "premium"
  displayName              String   @map("display_name")
  monthlyCalls             Int      @map("monthly_calls")
  priceCents               Int      @default(0) @map("price_cents")
  overagePricePer1000Cents Int      @default(0) @map("overage_price_per_1000_cents")
  maxGoogleAccounts        Int      @default(1) @map("max_google_accounts")
  features                 Json     @default("[]")
  isActive                 Boolean  @default(true) @map("is_active")
  sortOrder                Int      @default(0) @map("sort_order")
  createdAt                DateTime @default(now()) @map("created_at")

  subscriptions UserSubscription[]
  coupons       CouponCode[]

  @@map("plans")
}

// ============================================================
// User Plan Subscriptions
// ============================================================
model UserSubscription {
  id                   String    @id @default(uuid())
  userId               String    @unique @map("user_id")
  planId               String    @default("plan_free") @map("plan_id")
  status               String    @default("active") // active, past_due, cancelled, trialing
  callsUsed            Int       @default(0) @map("calls_used")
  periodStart          DateTime  @default(now()) @map("period_start")
  periodEnd            DateTime  @map("period_end")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  cancelledAt          DateTime? @map("cancelled_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("user_subscriptions")
}

// ============================================================
// Coupon Codes
// ============================================================
model CouponCode {
  id             String    @id @default(uuid())
  code           String    @unique
  planId         String    @map("plan_id")
  durationMonths Int       @default(1) @map("duration_months")
  maxRedemptions Int       @default(1) @map("max_redemptions")
  timesRedeemed  Int       @default(0) @map("times_redeemed")
  expiresAt      DateTime? @map("expires_at")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")

  plan        Plan               @relation(fields: [planId], references: [id])
  redemptions CouponRedemption[]

  @@map("coupon_codes")
}

model CouponRedemption {
  id         String   @id @default(uuid())
  couponId   String   @map("coupon_id")
  userId     String   @map("user_id")
  redeemedAt DateTime @default(now()) @map("redeemed_at")

  coupon CouponCode @relation(fields: [couponId], references: [id])
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@map("coupon_redemptions")
}

// ============================================================
// Support Tickets
// ============================================================
model SupportTicket {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  subject    String
  category   String    @default("general")
  status     String    @default("open") // open, in_progress, resolved, closed
  priority   String    @default("medium") // low, medium, high, urgent
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  resolvedAt DateTime? @map("resolved_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id         String   @id @default(uuid())
  ticketId   String   @map("ticket_id")
  userId     String?  @map("user_id")
  senderType String   @map("sender_type") // "user" | "admin"
  message    String
  createdAt  DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

// ============================================================
// Admin Notifications
// ============================================================
model AdminNotification {
  id        String   @id @default(uuid())
  type      String
  title     String
  message   String
  severity  String   @default("info") // info, warning, error, success
  isRead    Boolean  @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_notifications")
}

// ============================================================
// Activity Log (audit trail)
// ============================================================
model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("activity_log")
}

// ============================================================
// Google OAuth Credentials (for accessing GSC API)
// ============================================================
model GoogleCredential {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  googleEmail           String   @map("google_email")
  accessTokenEncrypted  String   @map("access_token_encrypted")
  refreshTokenEncrypted String   @map("refresh_token_encrypted")
  tokenExpiry           DateTime @map("token_expiry")
  scopes                String   @default("")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties     GscProperty[]
  ga4Properties  Ga4Property[]

  @@map("google_credentials")
}

// ============================================================
// GSC Properties (sites connected to the user's account)
// ============================================================
model GscProperty {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  credentialId    String   @map("credential_id")
  siteUrl         String   @map("site_url") // e.g., "https://example.com/" or "sc-domain:example.com"
  permissionLevel String   @map("permission_level") // siteOwner, siteFullUser, etc.
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential GoogleCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  oauthTokens OAuthToken[]
  authCodes   OAuthAuthorizationCode[]

  @@unique([userId, siteUrl])
  @@map("gsc_properties")
}

// ============================================================
// API Keys (for Claude Desktop / Cursor authentication)
// ============================================================
model ApiKey {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  keyHash   String    @unique @map("key_hash") // SHA-256 hash
  keyPrefix String    @map("key_prefix") // First 8 chars for display
  name      String    @default("Default")
  isActive  Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ============================================================
// OAuth Clients (registered via Dynamic Client Registration)
// ============================================================
model OAuthClient {
  id                      String   @id @default(uuid())
  clientId                String   @unique @map("client_id")
  clientSecretHash        String   @map("client_secret_hash")
  clientName              String   @default("Unknown") @map("client_name")
  redirectUris            String[] @map("redirect_uris")
  grantTypes              String[] @default(["authorization_code", "refresh_token"]) @map("grant_types")
  tokenEndpointAuthMethod String   @default("client_secret_post") @map("token_endpoint_auth_method")
  createdAt               DateTime @default(now()) @map("created_at")

  @@map("oauth_clients")
}

// ============================================================
// OAuth Tokens (issued to Claude/ChatGPT for MCP access)
// ============================================================
model OAuthToken {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  clientId         String   @map("client_id")
  accessTokenHash  String   @unique @map("access_token_hash")
  refreshTokenHash String?  @unique @map("refresh_token_hash")
  propertyId       String   @map("property_id")
  scopes           String   @default("gsc:read")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  property GscProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("oauth_tokens")
}

// ============================================================
// OAuth Authorization Codes (short-lived, single-use)
// ============================================================
model OAuthAuthorizationCode {
  id                  String   @id @default(uuid())
  codeHash            String   @unique @map("code_hash")
  userId              String   @map("user_id")
  clientId            String   @map("client_id")
  redirectUri         String   @map("redirect_uri")
  propertyId          String   @map("property_id")
  codeChallenge       String?  @map("code_challenge")
  codeChallengeMethod String?  @map("code_challenge_method")
  scopes              String   @default("gsc:read")
  expiresAt           DateTime @map("expires_at")
  used                Boolean  @default(false)
  createdAt           DateTime @default(now()) @map("created_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  property GscProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("oauth_authorization_codes")
}

// ============================================================
// GA4 Properties (Google Analytics 4 properties per user)
// ============================================================
model Ga4Property {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  credentialId String  @map("credential_id")
  propertyId  String   @map("property_id") // e.g. "properties/987654321"
  displayName String   @map("display_name") // e.g. "nandhini.com"
  accountName String?  @map("account_name") // e.g. "My Company"
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential GoogleCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("ga4_properties")
}

// ============================================================
// Usage Tracking
// ============================================================
model UsageLog {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  toolName       String   @map("tool_name")
  siteUrl        String   @map("site_url")
  source         String   @default("mcp") // e.g. "Claude.ai", "ChatGPT", API key name
  status         String   @default("success") // "success" or "error"
  responseTimeMs Int?     @map("response_time_ms")
  service        String   @default("gsc") // "gsc" or "ga4"
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([userId, toolName])
  @@map("usage_logs")
}

// ============================================================
// MCP Debug Logs (structured request/response/error logging)
// ============================================================
model McpDebugLog {
  id             String   @id @default(uuid())
  timestamp      DateTime @default(now())
  tool           String   @default("unknown")
  siteUrl        String   @default("unknown") @map("site_url")
  userId         String   @default("unknown") @map("user_id")
  status         String   @default("unknown") // "success" | "error" | "timeout"
  errorMessage   String?  @map("error_message")
  stack          String?
  responseTimeMs Int?     @map("response_time_ms")
  requestBody    String?  @map("request_body")
  responseBody   String?  @map("response_body")
  service        String   @default("gsc") // "gsc" or "ga4"

  @@index([timestamp])
  @@index([userId, timestamp])
  @@index([status, timestamp])
  @@index([tool, timestamp])
  @@map("mcp_debug_logs")
}
